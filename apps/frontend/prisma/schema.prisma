// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // hashed with bcrypt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  users             User[]
  connections       Connection[]
  pipedreamTriggers PipedreamTrigger[]
  runs              Run[]
  auditLogs         AuditLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([slug])
}

model Run {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowId      String?
  eventId         String  
  invocationId    String   @unique // idempotency key
  mode            String   
  status          String 
  eventSnapshot   Json?
  contextPointers Json?
  agentRequest    Json?
  agentResponse   Json?
  humanDecision   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  auditLogs      AuditLog[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([eventId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runId        String?
  run          Run?     @relation(fields: [runId], references: [id], onDelete: SetNull)
  eventId      String?
  invocationId String?
  action       String   
  actor        String?
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([runId, createdAt])
  @@index([eventId])
  @@index([invocationId])
}

model Connection {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        String   // "intercom", "slack", "stripe", etc.
  accessToken     String?  // encrypted (optional for Pipedream-managed connections)
  refreshToken    String?  // encrypted
  expiresAt       DateTime?
  pipedreamAuthId String?  // Pipedream account ID (apn_xxx) for managed connections
  metadata        Json?    // workspace info, webhook config, etc.
  status          String   @default("active") // "active", "inactive", "error"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  triggers PipedreamTrigger[]

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
  @@index([pipedreamAuthId])
}

model PipedreamTrigger {
  id              String     @id @default(cuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectionId    String
  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  triggerId       String     // Pipedream trigger component ID (e.g., "slack-new-message")
  deploymentId    String     @unique // Pipedream deployment ID (dc_xxx)
  configuredProps Json?      // Filter configuration (channels, event types, etc.)
  status          String     @default("active") // "active", "paused", "error"
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([tenantId])
  @@index([connectionId])
  @@index([deploymentId])
}
