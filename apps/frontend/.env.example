# Chronicle frontend configuration
# Copy this file to .env.local for local development.

# WorkOS (auth)
# Docs: https://workos.com/docs/authkit/nextjs#set-secrets
WORKOS_API_KEY=sk_test_replace_me
WORKOS_CLIENT_ID=client_replace_me
# Must match a Redirect URI configured in the WorkOS Dashboard
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
# 32+ chars used to encrypt the session cookie. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace-me-32-or-more-characters-please
# Webhook signing secret (set in CP 8)
WORKOS_WEBHOOK_SECRET=

# Must match the backend SERVICE_SECRET for server-to-server requests
SERVICE_SECRET=generate-another-secret-at-least-32-characters

# Encryption for stored tokens (64 hex chars = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Frontend URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
EVENTS_MANAGER_URL=http://localhost:8080

# Logo.dev
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
