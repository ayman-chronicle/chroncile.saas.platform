{
  "name": "@events-manager/timeline",
  "version": "0.1.0",
  "description": "Embeddable timeline viewer widget for React/web applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "cd .. && ./build-wasm.sh",
    "build:js": "tsup",
    "build": "npm run build:wasm && npm run build:js",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "timeline",
    "events",
    "viewer",
    "react",
    "webassembly",
    "egui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aestheros/events-manager"
  }
}
