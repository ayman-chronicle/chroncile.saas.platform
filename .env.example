# Database (shared by backend and frontend during migration)
DATABASE_URL=postgresql://chronicle:chronicle_dev@localhost:5432/chronicle

# Rust Backend
API_HOST=0.0.0.0
API_PORT=8080
BACKEND_MODE=memory
RUST_LOG=info,tower_http=debug
STREAM_CHANNEL_CAPACITY=10000
STREAM_BUFFER_CAPACITY=100000
AUTH_SECRET=generate-a-secret-at-least-32-characters-long

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
AUTH_TRUST_HOST=true

# Encryption (64 hex chars = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Pipedream
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
